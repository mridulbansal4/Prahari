# Prahari backend config (copy to .env). All vars are optional — the default `embedded` profile
# runs with none of them. Never commit a real .env (it is gitignored).

# --- Profile ---------------------------------------------------------------------------------
# embedded (default; SQLite + local vector + template-synth). Runs on one box with NO external
#          services and NO containers. This is the supported way to run Prahari locally.
# production (Neo4j + Qdrant + Postgres, each a local install — no Docker required)
PRAHARI_PROFILE=embedded

# --- Reasoning model (CP-5) — set a key to get narrated answers (Full CP-9 rung) -------------
# Without a key, Prahari runs at the "-model" rung: grounded, cited, but structured (not prose).
#
# Google Gemini (the reasoning provider; a low-cost Flash-Lite model keeps token usage down):
# PRAHARI_GEMINI_API_KEY=AIza...
# PRAHARI_GEMINI_MODEL=gemini-flash-lite-latest      # lowest-cost tier
# PRAHARI_MODEL_MAX_OUTPUT_TOKENS=768                 # small cap = cheap/fast
#
# Air-gap alternative: run a local OpenAI-compatible server (e.g. Ollama) — no key, still Full rung.
# The Verifier re-checks every citation regardless of which provider is used (grounding, CP-2).

# --- Demo control (CP-9 ladder) --------------------------------------------------------------
# Force a degradation rung for the refusal demo: -model | -vector | -graph | -everything
# PRAHARI_FORCE_RUNG=-graph

# --- Production stores (only used when PRAHARI_PROFILE=production) -----------------------------
# Point these at LOCAL installs — Neo4j Community/Desktop, the Qdrant binary, a local Postgres.
# Nothing here needs a container.
# PRAHARI_GRAPH_URI=bolt://localhost:7687
# PRAHARI_GRAPH_USER=neo4j
# PRAHARI_GRAPH_PASSWORD=change-me
# PRAHARI_VECTOR_URL=http://localhost:6333
# PRAHARI_PG_DSN=postgresql://sentinel:sentinel-dev@localhost:5432/sentinel
# NOTE: PRAHARI_REDIS_URL exists as a setting but nothing reads it today — there is no queue,
# no broker and no worker tier. Streaming is an in-process async generator.

# --- OCR: text out of SCANNED pages (optional; default off) ------------------------------------
# Without a provider, scanned PDFs and images are QUARANTINED with a reason — never guessed at.
# auto | unlimited | paddle | none
# PRAHARI_OCR_PROVIDER=none
# Unlimited-OCR served by a local vLLM/SGLang OpenAI-compatible endpoint. REQUIRES A GPU
# (or a hosted endpoint). Leave the URL empty and this provider reports itself unavailable.
# PRAHARI_UNLIMITED_OCR_BASE_URL=http://localhost:8001/v1
# PRAHARI_UNLIMITED_OCR_MODEL=Unlimited-OCR
# PRAHARI_UNLIMITED_OCR_MODE=gundam          # gundam = single page, base = multi-page
# PRAHARI_UNLIMITED_OCR_LOCAL=false          # in-process transformers path is NOT implemented
# PaddleOCR runs on CPU but is an optional install: pip install paddleocr paddlepaddle
# PRAHARI_PADDLE_OCR_LANG=en
# PRAHARI_OCR_DPI=300

# --- VLM: reasoning over engineering DRAWINGS (optional; default off) --------------------------
# This is NOT OCR. It reads a P&ID and reports components, connectivity and ratings as JSON,
# which becomes graph nodes and edges. Without a provider, drawings are QUARANTINED — topology
# is never invented. Billed per call when using a hosted endpoint.
# cosmos | openai_vision | local | none
# PRAHARI_VLM_PROVIDER=none
# PRAHARI_NVIDIA_API_KEY=nvapi-...
# PRAHARI_COSMOS_BASE_URL=https://integrate.api.nvidia.com/v1
# PRAHARI_COSMOS_MODEL=nvidia/cosmos3-nano-reasoner
# Any other OpenAI-compatible vision endpoint (provider=openai_vision or local):
# PRAHARI_VLM_BASE_URL=http://localhost:8002/v1
# PRAHARI_VLM_MODEL=qwen2-vl-7b
# PRAHARI_VLM_API_KEY=
# PRAHARI_DRAWING_DPI=200

# --- Real OIDC (production identity; when set, replaces the dev persona stub) -----------------
# PRAHARI_OIDC_JWKS_URI=https://login.example.com/.well-known/jwks.json
# PRAHARI_OIDC_ISSUER=https://login.example.com/
# PRAHARI_OIDC_AUDIENCE=prahari
# PRAHARI_OIDC_ROLE_CLAIM=role
